# =============================================================================
# LIVE / PRODUCTION — copy to the server as `.env` (adjust every placeholder).
# =============================================================================

APP_NAME=ApimsTec
APP_ENV=production
APP_KEY=base64:ZPeQyV/lmCtskNvVDsiD4jImjGKeCdQRG36/NS/frDs=
APP_DEBUG=false
APP_URL=https://app.apimstec.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# --- Registry DB (users, domains, sessions metadata) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=app-apimstec-db
DB_USERNAME=app-apimstec-user
DB_PASSWORD=App-apimstec-pass

# --- Sessions (must use mysql connection name when driver=database) ---
SESSION_DRIVER=database
SESSION_CONNECTION=mysql
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# database | redis (redis recommended at scale; set REDIS_* below)
CACHE_STORE=database
CORS_ORIGINS_CACHE_TTL=3600

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Google OAuth (CMS SEO / Search Console) ---
GOOGLE_CLIENT_ID=....apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=....
GOOGLE_GSC_REDIRECT_URI="${APP_URL}/oauth/google-search-console/callback"

# --- Public contact form fallback (CMS Content Manager email overrides when set) ---
CONTACT_FORM_MAIL_TO=support@example.com
CONTACT_FORM_SITE_NAME=Compress PDF

# --- CORS: comma-separated origins for React / other frontends hitting the API ---
# Include each live frontend origin (scheme + host, no trailing slash).
CORS_ALLOWED_ORIGINS=https://compresspdf.id,https://www.compresspdf.id

# --- Active tenant DB template (often overwritten per domain switch in app; set defaults for CLI) ---
CMS_TENANT_HOST=127.0.0.1
CMS_TENANT_PORT=3306
CMS_TENANT_DATABASE=compresspdf_db
CMS_TENANT_USERNAME=compresspdf_user
CMS_TENANT_PASSWORD=Compresspdf_pass

# --- Mail (required for contact form + notifications in production) ---
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Behind reverse proxy / load balancer (Cloudflare, nginx): TRUSTED_PROXIES=* or comma-separated IPs
# TRUSTED_PROXIES=*

# Laravel Vite (Inertia CMS UI build)
VITE_APP_NAME="${APP_NAME}"

# React marketing site build (mirror project root .env.production; not used by Laravel public API, optional if you never build the SPA from the CMS host)
VITE_API_URL=https://app.apimstec.com
VITE_SITE_DOMAIN=compresspdf.id
VITE_BUILD_SEO_LOCALE=en
VITE_PUBLIC_SITE_NAME=Compress PDF
VITE_API_DOMAIN_PATH=true
VITE_CMS_CACHE_MS=120000
VITE_CMS_SESSION_CACHE=true
VITE_FETCH_SEO_FILES=true
VITE_CMS_PREFETCH_LOCALES=id,en,ms,es,fr,ar,ru
VITE_USE_CMS_MEDIA_PROXY=false
